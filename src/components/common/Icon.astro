---
type Props = {
  class?: string;
  icon: string;
  inline?: boolean;
};
const { icon, inline, class: className } = Astro.props;
---

{
  // Intentional, iconify-icon checks for the presence
  // of the inline attribute, not its value. So we only
  // want to include it if it's true.
}
<iconify-icon class={className} {...!!inline && { inline }} icon={icon}
></iconify-icon>
